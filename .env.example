## Constance Conservation — Environment Variables (template)
## Copy to .env and fill in real values

# Safety Culture API
SAFETY_CULTURE_API_TOKEN=<bearer token from Safety Culture settings>
SAFETY_CULTURE_ORG_ID=<organisation ID>

# Supabase
SUPABASE_PROJECT_REF=<project ref from Supabase dashboard>
SUPABASE_URL=<https://[ref].supabase.co>
SUPABASE_ANON_KEY=<publishable/anon key>
SUPABASE_SERVICE_ROLE_KEY=<service role key — keep secret>
SUPABASE_DB_PASSWORD=<database password>
SUPABASE_DB_URL=<postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres>
